<div id="body-wrapper">
  <div id="skip-content"><a class="Skip-btn" href="#skipToContent">Skip To Main
      Content</a></div>
  <!-- Header Section -->
  <header id="header" class="main-header sticky-header">
    {{render "@global-header"}}
    {{> '@site-navigation--stacked' navigation }}
  </header>
  <!-- Header Section End -->
  <!-- Main Content Body -->
  <!-- {{ banner.text }} -->
  <div id="main" role="main">
    <!--Slider -->
   {{> '@banner--video' context=banner }}
    <!-- End Slider -->
    <div id="skipToContent"></div>
    {{render "@quickfacts--grey"}}

    <!-- Call To Action - Buttons Only - No Image -->
    {{render "@call-to-action-buttons--grey"}}
    <!-- End Call To Action -->

    <!-- Call To Action - Button with Image -->
    {{render "@call-to-action-media"}}
    <!-- End Call To Action -->

    <!-- Call To Action - Button with Image (on Left) -->
    {{render "@call-to-action-media--left"}}
    <!-- End Call To Action -->

    <!-- ENROLLMENT CTA -->
    {{render "@enrollment-call-to-action"}}
    <!-- END CTA -->
  </div>
  {{render "@back-to-top"}}
  <!-- End Main Content Body -->
  {{render "@global-footer"}}
</div>